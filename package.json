{
	"name": "@ac/monorepo",
	"private": true,
	"packageManager": "pnpm@10.33.1",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "pnpm --filter \"./apps/**\" run dev",
		"build": "pnpm --filter \"./apps/**\" run build",
		"check": "pnpm --filter \"./apps/**\" run check",
		"db:generate": "pnpm --filter @ac/db run db:generate",
		"db:push": "pnpm --filter @ac/db run db:push",
		"db:pull": "pnpm --filter @ac/db run db:pull",
		"db:check": "pnpm --filter @ac/db run db:check"
	},
	"devDependencies": {
		"typescript": "~6.0.3"
	},
	"overrides": {
		"typescript": "~6.0.3",
		"vite": "^8.0.0",
		"svelte": "^5.55.1",
		"drizzle-orm": "0.45.2",
		"drizzle-kit": "0.31.10"
	},
	"pnpm": {
		"overrides": {
			"svelte": "^5.55.1",
			"drizzle-orm": "0.45.2",
			"drizzle-kit": "0.31.10",
			"typescript": "~6.0.3"
		}
	},
	"dependencies": {
		"@rolldown/binding-win32-x64-msvc": "1.0.0-rc.18",
		"@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
		"valibot": "^1.3.1"
	}
}